<?xml version="1.0" encoding="utf-8"?>
<!--
    Map marker for a member currently ONLINE. Deliberately larger and higher-
    contrast than the tiny generic android.R.drawable.presence_online dot
    previously used here, which was hard to make out at typical map zoom
    levels. A plain two-tone vector (white ring + solid fill) is cheap to
    render (no gradients/shadows) and keeps online vs. offline members
    clearly distinguishable at a glance, not just by a subtle shade
    difference.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="28dp"
    android:height="28dp"
    android:viewportWidth="28"
    android:viewportHeight="28">
    <path
        android:fillColor="#FFFFFFFF"
        android:pathData="M14,1 C6.82,1 1,6.82 1,14 C1,21.18 6.82,27 14,27 C21.18,27 27,21.18 27,14 C27,6.82 21.18,1 14,1 Z"/>
    <path
        android:fillColor="#FF2E7D32"
        android:pathData="M14,4.5 C8.753,4.5 4.5,8.753 4.5,14 C4.5,19.247 8.753,23.5 14,23.5 C19.247,23.5 23.5,19.247 23.5,14 C23.5,8.753 19.247,4.5 14,4.5 Z"/>
</vector>
