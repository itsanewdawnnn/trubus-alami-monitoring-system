<?xml version="1.0" encoding="utf-8"?>
<!--
    Map marker for the START point of a Member's recorded travel history
    (Admin > Trip History). Same white-ring-plus-colored-disc family as
    ic_marker_online/offline for visual consistency, but with a white "play"
    triangle glyph inside so it reads as "start" using the exact same icon
    language as the Member dashboard's own START button (Icons.Default.
    PlayArrow) : no separate legend/explanation is needed to recognize it.
    Green fill matches the app's existing "active/positive" marker color.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="28dp"
    android:height="28dp"
    android:viewportWidth="28"
    android:viewportHeight="28">
    <path
        android:fillColor="#FFFFFFFF"
        android:pathData="M14,1 C6.82,1 1,6.82 1,14 C1,21.18 6.82,27 14,27 C21.18,27 27,21.18 27,14 C27,6.82 21.18,1 14,1 Z"/>
    <path
        android:fillColor="#FF2E7D32"
        android:pathData="M14,4.5 C8.753,4.5 4.5,8.753 4.5,14 C4.5,19.247 8.753,23.5 14,23.5 C19.247,23.5 23.5,19.247 23.5,14 C23.5,8.753 19.247,4.5 14,4.5 Z"/>
    <path
        android:fillColor="#FFFFFFFF"
        android:pathData="M11.5,10 L11.5,18 L18,14 Z"/>
</vector>
